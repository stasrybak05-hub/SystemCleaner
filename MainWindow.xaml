<Window x:Class="SystemCleaner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SystemCleaner"
        Title="{DynamicResource AppTitle}"
        Width="1100" Height="720" MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="🧹 System Cleaner" FontSize="22" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextBrush}"/>
            <TextBlock Text="   " FontSize="22"/>
            <TextBlock Text="{DynamicResource AppSubtitle}"
                       Style="{StaticResource SubText}" VerticalAlignment="Bottom"/>

            <!-- Перемикач теми -->
            <StackPanel Margin="24,0,0,0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{DynamicResource Lbl_Theme}" VerticalAlignment="Center" 
                           Margin="0,0,8,0" Style="{StaticResource SubText}"/>
                <ComboBox x:Name="ThemeSelector" Width="200"
                          Background="{DynamicResource ControlBackgroundBrush}"
                          Foreground="{DynamicResource TextBrush}"
                          SelectionChanged="ThemeSelector_SelectionChanged">
                    <ComboBoxItem Content="🌌 Темна (Dark)"/>
                    <ComboBoxItem Content="☀️ Світла (Light)"/>
                    <ComboBoxItem Content="🌊 Морська (Sea)"/>
                    <ComboBoxItem Content="🖤 Чорна OLED (Black)"/>
                    <ComboBoxItem Content="🌫 Сіра (Gray)"/>
                    <ComboBoxItem Content="🌅 Захід (Sunset)"/>
                </ComboBox>
            </StackPanel>

            <!-- Перемикач мови -->
            <StackPanel Margin="16,0,0,0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{DynamicResource Lbl_Language}" VerticalAlignment="Center" 
                           Margin="0,0,8,0" Style="{StaticResource SubText}"/>
                <ComboBox x:Name="LangSelector" Width="160"
                          Background="{DynamicResource ControlBackgroundBrush}"
                          Foreground="{DynamicResource TextBrush}"
                          SelectionChanged="LangSelector_SelectionChanged">
                    <ComboBoxItem Content="🇺🇦 Українська"/>
                    <ComboBoxItem Content="🇬🇧 English"/>
                    <ComboBoxItem Content="🇷🇺 Русский"/>
                </ComboBox>
            </StackPanel>
        </StackPanel>

        <!-- Вкладки -->
        <TabControl Grid.Row="1" Margin="0,0,0,12"
                    Background="{DynamicResource WindowBackgroundBrush}"
                    Foreground="{DynamicResource TextBrush}">

            <!-- ===== ОЧИЩЕННЯ ===== -->
            <TabItem Header="{DynamicResource Tab_Cleaning}">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Статистика -->
                    <Border Grid.Row="0" Background="{DynamicResource PanelBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="16" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{DynamicResource FoundJunk}" Style="{StaticResource SubText}"/>
                                <TextBlock x:Name="TotalSizeText" Text="0 Б" FontSize="24" FontWeight="Bold"
                                           Foreground="{DynamicResource TextBrush}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{DynamicResource FilesCount}" Style="{StaticResource SubText}"/>
                                <TextBlock x:Name="TotalCountText" Text="0" FontSize="24" FontWeight="Bold"
                                           Foreground="{DynamicResource TextBrush}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{DynamicResource Status}" Style="{StaticResource SubText}"/>
                                <TextBlock x:Name="StatusText" Text="{DynamicResource Ready}" FontSize="16"
                                           Foreground="{DynamicResource TextBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Список категорій -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="320"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <ListBox Grid.Column="0" x:Name="CategoriesList" Margin="0,0,8,0"
                                 Background="{DynamicResource PanelBackgroundBrush}"
                                 Foreground="{DynamicResource TextBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 SelectionChanged="CategoriesList_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding Selected, Mode=TwoWay}"
                                                  VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextBrush}"/>
                                            <TextBlock Style="{StaticResource SubText}">
                                                <Run Text="{Binding TotalCount, Mode=OneWay, StringFormat={}{0} файлів}"/>
                                                <Run Text=" — "/>
                                                <Run Text="{Binding TotalSize, Mode=OneWay, StringFormat={}{0:N0} Б}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Деталі -->
                        <Grid Grid.Column="1" Margin="8,0,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="{DynamicResource DetailsHint}"
                                       Style="{StaticResource SubText}" Margin="0,0,0,6"/>
                            <ListView Grid.Row="1" x:Name="ItemsList"
                                      Background="{DynamicResource PanelBackgroundBrush}"
                                      Foreground="{DynamicResource TextBrush}"
                                      BorderBrush="{DynamicResource BorderBrush}">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="" Width="30">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding Selected, Mode=TwoWay}"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="{DynamicResource Col_Path}" Width="500"
                                                        DisplayMemberBinding="{Binding Path}"/>
                                        <GridViewColumn Header="{DynamicResource Col_Size}" Width="120"
                                                        DisplayMemberBinding="{Binding SizeText}"/>
                                        <GridViewColumn Header="{DynamicResource Col_Type}" Width="80">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Foreground="{DynamicResource TextBrush}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="{DynamicResource Type_File}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                                                        <Setter Property="Text" Value="{DynamicResource Type_Folder}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Grid>
                    </Grid>

                    <!-- Прогрес і кнопки -->
                    <StackPanel Grid.Row="2" Margin="0,12,0,0">
                        <ProgressBar x:Name="ScanProgress" Height="6" Margin="0,0,0,8"/>
                        
                        <!-- ✅ НОВА ОПЦІЯ: Створення точки відновлення -->
                        <CheckBox x:Name="CreateRestorePointCheckBox"
                                  Content="{DynamicResource Opt_CreateRestorePoint}"
                                  IsChecked="True"
                                  Margin="0,0,0,8"
                                  Checked="CreateRestorePointCheckBox_Changed"
                                  Unchecked="CreateRestorePointCheckBox_Changed"/>
                        
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button x:Name="BtnScan" Content="{DynamicResource Btn_Scan}" Margin="4"
                                    Click="BtnScan_Click" MinWidth="160"/>
                            <Button x:Name="BtnClean" Content="{DynamicResource Btn_Clean}" Margin="4"
                                    Click="BtnClean_Click" MinWidth="160"/>
                            <Button x:Name="BtnCancel" Content="{DynamicResource Btn_Cancel}" Margin="4"
                                    Style="{StaticResource GhostButton}"
                                    Click="BtnCancel_Click" IsEnabled="False" MinWidth="160"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ===== ДОДАТКОВЕ ===== -->
            <TabItem Header="{DynamicResource Tab_Additional}">
                <StackPanel Margin="24">
                    <TextBlock Text="{DynamicResource QuickActions}" FontSize="18" FontWeight="SemiBold" 
                               Margin="0,0,0,12" Foreground="{DynamicResource TextBrush}"/>
                    <WrapPanel>
                        <Button Content="{DynamicResource ClearEventLogs}" Margin="6"
                                Click="ClearEventLogs_Click" MinWidth="280"/>
                        <Button Content="{DynamicResource FlushDns}" Margin="6"
                                Click="FlushDns_Click" MinWidth="280"/>
                        <Button Content="{DynamicResource ClearRunHistory}" Margin="6"
                                Click="ClearRunHistory_Click" MinWidth="280"/>
                        <Button Content="{DynamicResource ClearClipboard}" Margin="6"
                                Click="ClearClipboard_Click" MinWidth="280"/>
                        <Button Content="{DynamicResource ClearSearchCache}" Margin="6"
                                Click="ClearSearchCache_Click" MinWidth="280"/>
                    </WrapPanel>
                </StackPanel>
            </TabItem>

            <!-- ===== АВТОЗАПУСК ===== -->
            <TabItem Header="{DynamicResource Tab_Startup}">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="{DynamicResource Btn_Refresh}" Click="RefreshStartup_Click"/>
                        <TextBlock Text="    " FontSize="12"/>
                        <TextBlock Text="{DynamicResource StartupHint}"
                                   Style="{StaticResource SubText}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <ListView Grid.Row="1" x:Name="StartupList"
                              Background="{DynamicResource PanelBackgroundBrush}"
                              Foreground="{DynamicResource TextBrush}"
                              BorderBrush="{DynamicResource BorderBrush}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="{DynamicResource Col_Name}" Width="200"
                                                DisplayMemberBinding="{Binding Name}"/>
                                <GridViewColumn Header="{DynamicResource Col_Command}" Width="400"
                                                DisplayMemberBinding="{Binding Command}"/>
                                <GridViewColumn Header="{DynamicResource Col_Location}" Width="180"
                                                DisplayMemberBinding="{Binding Location}"/>
                                <GridViewColumn Header="{DynamicResource Col_Action}" Width="180">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="{DynamicResource Btn_Disable}" Margin="2"
                                                        Click="DisableStartup_Click" Tag="{Binding}"/>
                                                <Button Content="{DynamicResource Btn_Enable}" Margin="2"
                                                        Style="{StaticResource GhostButton}"
                                                        Click="EnableStartup_Click" Tag="{Binding}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </TabItem>
			
            <!-- ===== МОНІТОРИНГ СИСТЕМИ ===== -->
            <TabItem Header="{DynamicResource Tab_Monitor}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="12">
                    <StackPanel>
                        <!-- Заголовок -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource Monitor_Title}"
                                       FontSize="18" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button x:Name="BtnStartMonitor"
                                        Content="{DynamicResource Btn_StartMonitor}"
                                        Click="BtnStartMonitor_Click" MinWidth="140" Margin="0,0,8,0"/>
                                <Button x:Name="BtnStopMonitor"
                                        Content="{DynamicResource Btn_StopMonitor}"
                                        Style="{StaticResource GhostButton}"
                                        Click="BtnStopMonitor_Click" MinWidth="140" IsEnabled="False"/>
                            </StackPanel>
                        </Grid>

                        <!-- CPU -->
                        <Border Background="{DynamicResource PanelBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                CornerRadius="8" Padding="16" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="🖥 CPU" FontSize="16" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}"/>
                                    <TextBlock x:Name="CpuNameText" Text="—"
                                               Style="{StaticResource SubText}" Margin="0,4,0,0"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                        <TextBlock Text="{DynamicResource Monitor_Usage}" 
                                                   Style="{StaticResource SubText}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock x:Name="CpuUsageText" Text="0%" FontSize="20" FontWeight="Bold"
                                                   Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="   |   " Style="{StaticResource SubText}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{DynamicResource Monitor_Temp}"
                                                   Style="{StaticResource SubText}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock x:Name="CpuTempText" Text="—°C" FontSize="20" FontWeight="Bold"
                                                   Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <ProgressBar x:Name="CpuProgress" Height="8" Margin="0,12,0,0"
                                                 Value="0" Maximum="100"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- RAM -->
                        <Border Background="{DynamicResource PanelBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                CornerRadius="8" Padding="16" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="💾 RAM" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <TextBlock x:Name="RamText" Text="0 ГБ / 0 ГБ" FontSize="20" FontWeight="Bold"
                                               Foreground="{DynamicResource AccentBrush}"/>
                                    <TextBlock Text="   (" Style="{StaticResource SubText}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="RamPercentText" Text="0%" 
                                               Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <TextBlock Text=")" Style="{StaticResource SubText}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <ProgressBar x:Name="RamProgress" Height="8" Margin="0,12,0,0"
                                             Value="0" Maximum="100"/>
                            </StackPanel>
                        </Border>

                        <!-- GPU -->
                        <Border Background="{DynamicResource PanelBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                CornerRadius="8" Padding="16" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="🎮 GPU" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"/>
                                <TextBlock x:Name="GpuNameText" Text="—"
                                           Style="{StaticResource SubText}" Margin="0,4,0,0"/>
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <TextBlock Text="{DynamicResource Monitor_Temp}"
                                               Style="{StaticResource SubText}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock x:Name="GpuTempText" Text="—°C" FontSize="20" FontWeight="Bold"
                                               Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Диски та Мережа -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="{DynamicResource PanelBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    CornerRadius="8" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="💿 Disk" FontSize="16" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}"/>
                                    <TextBlock x:Name="DiskText" Text="↓0.0 МБ/с  ↑0.0 МБ/с"
                                               FontSize="16" Margin="0,8,0,0"
                                               Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Background="{DynamicResource PanelBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    CornerRadius="8" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="🌐 Network" FontSize="16" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}"/>
                                    <TextBlock x:Name="NetworkText" Text="↓0.00 МБ/с  ↑0.00 МБ/с"
                                               FontSize="16" Margin="0,8,0,0"
                                               Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Система -->
                        <Border Background="{DynamicResource PanelBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                CornerRadius="8" Padding="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="🖥 OS" Style="{StaticResource SubText}"/>
                                    <TextBlock x:Name="OsNameText" Text="—" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}" Margin="0,4,0,0"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="⏱ Uptime" Style="{StaticResource SubText}"/>
                                    <TextBlock x:Name="UptimeText" Text="—" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="🔋 Battery" Style="{StaticResource SubText}"/>
                                    <TextBlock x:Name="BatteryText" Text="—" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- ===== ПРОГРАМИ (Деінсталятор) ===== -->
            <TabItem Header="{DynamicResource Tab_Programs}">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Заголовок і пошук -->
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" x:Name="BtnLoadPrograms"
                                Content="{DynamicResource Btn_LoadPrograms}"
                                Click="BtnLoadPrograms_Click" MinWidth="160" Margin="0,0,8,0"/>

                        <TextBox Grid.Column="1" x:Name="ProgramsSearchBox"
                                 Background="{DynamicResource ControlBackgroundBrush}"
                                 Foreground="{DynamicResource TextBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 Padding="10,6" Margin="0,0,8,0"
                                 TextChanged="ProgramsSearchBox_TextChanged"/>

                        <Button Grid.Column="2" x:Name="BtnCalculateSizes"
                                Content="{DynamicResource Btn_CalculateSizes}"
                                Style="{StaticResource GhostButton}"
                                Click="BtnCalculateSizes_Click" MinWidth="200"/>
                    </Grid>

                    <!-- Статистика -->
                    <Border Grid.Row="1" Background="{DynamicResource PanelBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="12" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource Programs_Total}"
                                       Style="{StaticResource SubText}" Margin="0,0,8,0"/>
                            <TextBlock x:Name="ProgramsTotalCount" Text="0" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}" Margin="0,0,24,0"/>
                            <TextBlock Text="{DynamicResource Programs_TotalSize}"
                                       Style="{StaticResource SubText}" Margin="0,0,8,0"/>
                            <TextBlock x:Name="ProgramsTotalSize" Text="—" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Список програм -->
                    <ListView Grid.Row="2" x:Name="ProgramsList"
                              Background="{DynamicResource PanelBackgroundBrush}"
                              Foreground="{DynamicResource TextBrush}"
                              BorderBrush="{DynamicResource BorderBrush}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="{DynamicResource Col_ProgramName}" Width="320"
                                                DisplayMemberBinding="{Binding Name}"/>
                                <GridViewColumn Header="{DynamicResource Col_Publisher}" Width="180"
                                                DisplayMemberBinding="{Binding Publisher}"/>
                                <GridViewColumn Header="{DynamicResource Col_Version}" Width="110"
                                                DisplayMemberBinding="{Binding Version}"/>
                                <GridViewColumn Header="{DynamicResource Col_Size}" Width="110"
                                                DisplayMemberBinding="{Binding SizeText}"/>
                                <GridViewColumn Header="{DynamicResource Col_InstallDate}" Width="110"
                                                DisplayMemberBinding="{Binding FormattedDate}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <!-- Кнопки дій -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal"
                                HorizontalAlignment="Center" Margin="0,12,0,0">
                        <Button x:Name="BtnUninstall"
                                Content="{DynamicResource Btn_Uninstall}"
                                Click="BtnUninstall_Click" MinWidth="180" Margin="4"/>
                        <Button x:Name="BtnForceUninstall"
                                Content="{DynamicResource Btn_ForceUninstall}"
                                Style="{StaticResource GhostButton}"
                                Click="BtnForceUninstall_Click" MinWidth="220" Margin="4"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ===== АНАЛІЗ ДИСКА ===== -->
            <TabItem Header="{DynamicResource Tab_DiskAnalysis}">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="{DynamicResource SelectDrives}" Margin="0,0,0,6"
                                   Foreground="{DynamicResource TextBrush}"/>
                        <ListBox x:Name="DriveList" Height="120"
                                 Background="{DynamicResource PanelBackgroundBrush}"
                                 Foreground="{DynamicResource TextBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 SelectionMode="Multiple"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button x:Name="BtnFindLarge" Content="{DynamicResource FindLarge}"
                                Click="FindLargeFiles_Click" Margin="4" MinWidth="280"/>
                        <Button x:Name="BtnFindDuplicates" Content="{DynamicResource FindDuplicates}"
                                Click="FindDuplicates_Click" Margin="4" MinWidth="280"/>
                        <Button Content="{DynamicResource Btn_Cancel}" Style="{StaticResource GhostButton}"
                                Click="BtnCancelAnalysis_Click" Margin="4" MinWidth="160"/>
                    </StackPanel>

                    <TextBlock Grid.Row="2" Margin="0,4,0,4" FontWeight="SemiBold"
                               x:Name="LargeFilesLabel" Text="{DynamicResource LargeFiles}"
                               Foreground="{DynamicResource TextBrush}"/>
                    <ListView Grid.Row="2" x:Name="LargeFilesList" Margin="0,28,0,0"
                              Background="{DynamicResource PanelBackgroundBrush}"
                              Foreground="{DynamicResource TextBrush}"
                              BorderBrush="{DynamicResource BorderBrush}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="{DynamicResource Col_Size}" Width="100"
                                                DisplayMemberBinding="{Binding SizeText}"/>
                                <GridViewColumn Header="{DynamicResource Col_Path}" Width="800"
                                                DisplayMemberBinding="{Binding Path}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <TextBlock Grid.Row="3" Margin="0,8,0,4" FontWeight="SemiBold"
                               x:Name="DuplicatesLabel" Text="{DynamicResource Duplicates}"
                               Foreground="{DynamicResource TextBrush}"/>
                    <ListView Grid.Row="4" x:Name="DuplicatesList" Margin="0,28,0,0"
                              Background="{DynamicResource PanelBackgroundBrush}"
                              Foreground="{DynamicResource TextBrush}"
                              BorderBrush="{DynamicResource BorderBrush}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="{DynamicResource Col_Size}" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Size, StringFormat={}{0:N0} Б}"
                                                       Foreground="{DynamicResource TextBrush}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="{DynamicResource Col_Copies}" Width="800">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock TextWrapping="Wrap" Text="{Binding PathsText}"
                                                       Foreground="{DynamicResource TextBrush}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </TabItem>

            <!-- ===== ПРО ПРОГРАМУ ===== -->
            <TabItem Header="{DynamicResource Tab_About}">
                <StackPanel Margin="24">
                    <TextBlock Text="System Cleaner" FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource TextBrush}"/>
                    <TextBlock Text="{DynamicResource AboutVersion}" Style="{StaticResource SubText}"/>
                    <TextBlock Text="{DynamicResource AboutText}" TextWrapping="Wrap" Margin="0,16,0,0"
                               Foreground="{DynamicResource TextBrush}"/>
                    <TextBlock Text="{DynamicResource AboutWarning}" Margin="0,16,0,0"
                               Foreground="{DynamicResource DangerBrush}" FontWeight="SemiBold"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- Нижній статус -->
        <Border Grid.Row="2" Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="6" Padding="12,8">
            <TextBlock x:Name="GlobalStatus" Text="{DynamicResource Status_Ready}"
                       Foreground="{DynamicResource TextBrush}"/>
        </Border>
    </Grid>
</Window>