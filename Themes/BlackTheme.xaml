<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FF000000"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FF0A0A0A"/>
    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#FF141414"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#FF00D4FF"/>
    <SolidColorBrush x:Key="DangerBrush" Color="#FFFF3B30"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#FF30D158"/>
    <SolidColorBrush x:Key="TextBrush" Color="#FFFFFFFF"/>
